{
  "info": {
    "name": "StudyMarket REST API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8082"
    },
    {
      "key": "username",
      "value": "seller"
    },
    {
      "key": "password",
      "value": "password"
    }
  ],
  "item": [
    {
      "name": "List products",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/products"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('returns products', function () {",
              "  pm.response.to.have.status(200);",
              "  pm.expect(pm.response.json()).to.be.an('array');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Create product",
      "request": {
        "auth": {
          "type": "basic",
          "basic": [
            {
              "key": "username",
              "value": "{{username}}",
              "type": "string"
            },
            {
              "key": "password",
              "value": "{{password}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Postman demo notebook\",\n  \"description\": \"Аккуратный конспект для проверки REST API и OpenAPI на защите.\",\n  \"price\": 500,\n  \"campus\": \"Главный корпус\",\n  \"imageUrl\": \"/images/studymarket-hero.png\",\n  \"condition\": \"GOOD\",\n  \"categoryIds\": [1, 2]\n}"
        },
        "url": "{{baseUrl}}/api/products"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('created', function () {",
              "  pm.response.to.have.status(201);",
              "  pm.collectionVariables.set('productId', pm.response.json().id);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Get product",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/products/{{productId}}"
      }
    },
    {
      "name": "Update product",
      "request": {
        "auth": {
          "type": "basic",
          "basic": [
            {
              "key": "username",
              "value": "{{username}}",
              "type": "string"
            },
            {
              "key": "password",
              "value": "{{password}}",
              "type": "string"
            }
          ]
        },
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Updated Postman demo notebook\",\n  \"description\": \"Обновленная карточка товара через REST API.\",\n  \"price\": 650,\n  \"campus\": \"Библиотека\",\n  \"imageUrl\": \"/images/studymarket-hero.png\",\n  \"condition\": \"EXCELLENT\",\n  \"categoryIds\": [1, 2]\n}"
        },
        "url": "{{baseUrl}}/api/products/{{productId}}"
      }
    },
    {
      "name": "Delete product",
      "request": {
        "auth": {
          "type": "basic",
          "basic": [
            {
              "key": "username",
              "value": "{{username}}",
              "type": "string"
            },
            {
              "key": "password",
              "value": "{{password}}",
              "type": "string"
            }
          ]
        },
        "method": "DELETE",
        "url": "{{baseUrl}}/api/products/{{productId}}"
      }
    }
  ]
}
